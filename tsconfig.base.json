{
    "compilerOptions": {
      "target": "ES2022",
      "module": "ESNext",
      "moduleResolution": "Node",
      "strict": true,
      "skipLibCheck": true,
      "baseUrl": ".",
      "paths": {
        "@api/*": ["apps/api/src/*"],
        "@web/*": ["apps/web/*"],
        "@mobile/*": ["apps/mobile/src/*"],
        "@packages/*": ["packages/*"]
      }
    }
  }